                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Lessons/{id}": {
      "get": {
        "tags": [
          "Lessons"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
